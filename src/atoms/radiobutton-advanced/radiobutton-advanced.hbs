<fieldset class="field-group m-form-control a-radiobutton-advanced js-radiobutton-advanced{{#if is_invalid}} is-invalid{{/if}}">
	<legend class="label-legend">{{legend}}</legend>
	{{#each options}}
		<div class="radio a-radiobutton-advanced__option js-radiobutton-advanced__option{{#if ../is_invalid}} is-invalid{{/if}}">
			<input type="radio" id="{{id}}" name="{{../name}}" value="{{value}}" class="a-radio u-visuallyhidden js-radiobutton-advanced__input"{{#if is_checked}} checked{{/if}}{{#if ../is_disabled}} disabled{{else}}{{#if is_disabled}} disabled{{/if}}{{/if}}{{#if ../is_required}} required{{else}}{{#if is_required}} required{{/if}}{{/if}}{{#if ../is_invalid}} aria-invalid="true"{{else}}{{#if is_invalid}} aria-invalid="true"{{/if}}{{/if}}>
			<label for="{{id}}">
				<span class="a-radiobutton-advanced__content">
					<span class="a-radiobutton-advanced__label">{{label}}</span>
					{{#if description}}<span class="a-radiobutton-advanced__description">{{description}}</span>{{/if}}
				</span>
			</label>
		</div>
	{{/each}}
</fieldset>
